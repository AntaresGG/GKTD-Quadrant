<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadrantGTD.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
        xmlns:behaviors="using:QuadrantGTD.Behaviors"
        xmlns:models="using:QuadrantGTD.Models"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="QuadrantGTD.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/GKTD.ico"
        Title="{DynamicResource AppTitle}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                Padding="24,16"
                BoxShadow="0 1 3 0 #05000000">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Logo & Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <Border Width="40" Height="40" Background="{StaticResource PrimaryBrush}" CornerRadius="10">
                        <TextBlock Text="G" Foreground="White" FontSize="20" FontWeight="Bold" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource AppTitle}" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="{DynamicResource AppSubtitle}" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Classes="SecondaryHeaderButton" Command="{Binding ToggleLanguageCommand}" 
                            ToolTip.Tip="{DynamicResource SwitchLanguage}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🌐"/>
                            <TextBlock Text="{Binding ToggleLanguageButtonText, FallbackValue='EN/ZH'}"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Content="{DynamicResource AddTask}"
                            Classes="HeaderButton"
                            Command="{Binding ShowAddTaskCommand}"/>
                            
                    <Button Content="{DynamicResource ProjectManagement}"
                            Classes="SecondaryHeaderButton"
                            Command="{Binding ShowProjectManagementCommand}"/>
                            
                    <Button Content="{Binding ToggleButtonText}"
                            Classes="SecondaryHeaderButton"
                            Command="{Binding ToggleViewCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
            <!-- Left Sidebar -->
            <Border Grid.Column="0"
                    Width="240"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,1,0"
                    IsVisible="{Binding !ShowCompletedView}">
                <ScrollViewer>
                    <Border Padding="16,24">
                        <StackPanel Spacing="8">
                            <TextBlock Text="PROJECT FILTER"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#94A3B8"
                                       Margin="8,0,0,8"/>

                            <!-- All Projects -->
                            <Button Classes="ProjectFilterButton"
                                    Background="{Binding AllProjectsFilterBackground}"
                                    Command="{Binding ToggleProjectFilterCommand}"
                                    CommandParameter="{x:Null}"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="📂"/>
                                    <TextBlock Text="{DynamicResource AllProjects}" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>

                            <!-- Project List -->
                            <ItemsControl ItemsSource="{Binding Projects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Project">
                                        <Button Classes="ProjectFilterButton"
                                                Command="{Binding $parent[Window].DataContext.ToggleProjectFilterCommand}"
                                                CommandParameter="{Binding Id}"
                                                HorizontalAlignment="Stretch">
                                            <Grid ColumnDefinitions="Auto, *">
                                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding Color}" Margin="4,0,14,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1" IsVisible="{Binding !ShowCompletedView}">
                <Grid RowDefinitions="*, *" ColumnDefinitions="*, *" Margin="24">
                    
                    <!-- Q1: Urgent & Important -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#FFF1F2" BorderBrush="#FDA4AF" BorderThickness="1" CornerRadius="16" Margin="0,0,10,10">
                        <i:Interaction.Behaviors>
                            <behaviors:DropTargetBehavior TargetQuadrant="UrgentImportant" MoveTaskCommand="{Binding MoveTaskToQuadrantCommand}"/>
                        </i:Interaction.Behaviors>
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Padding="20,16" Background="#FFE4E6" CornerRadius="16,16,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="🎯" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Q1Title}" FontWeight="Bold" Foreground="#9F1239" FontSize="16"/>
                                        <TextBlock Text="{DynamicResource Q1Subtitle}" FontSize="11" Foreground="#BE123C" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Padding="16">
                                <ItemsControl ItemsSource="{Binding Q1Tasks}">
                                    <ItemsControl.ItemTemplate><StaticResource ResourceKey="TaskItemTemplate"/></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Q2: Not Urgent & Important -->
                    <Border Grid.Row="0" Grid.Column="1" Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="16" Margin="10,0,0,10">
                        <i:Interaction.Behaviors>
                            <behaviors:DropTargetBehavior TargetQuadrant="NotUrgentImportant" MoveTaskCommand="{Binding MoveTaskToQuadrantCommand}"/>
                        </i:Interaction.Behaviors>
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Padding="20,16" Background="#DCFCE7" CornerRadius="16,16,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="💎" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Q2Title}" FontWeight="Bold" Foreground="#166534" FontSize="16"/>
                                        <TextBlock Text="{DynamicResource Q2Subtitle}" FontSize="11" Foreground="#15803D" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Padding="16">
                                <ItemsControl ItemsSource="{Binding Q2Tasks}">
                                    <ItemsControl.ItemTemplate><StaticResource ResourceKey="TaskItemTemplate"/></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Q3: Urgent & Not Important -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#F0F9FF" BorderBrush="#7DD3FC" BorderThickness="1" CornerRadius="16" Margin="0,10,10,0">
                        <i:Interaction.Behaviors>
                            <behaviors:DropTargetBehavior TargetQuadrant="UrgentNotImportant" MoveTaskCommand="{Binding MoveTaskToQuadrantCommand}"/>
                        </i:Interaction.Behaviors>
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Padding="20,16" Background="#E0F2FE" CornerRadius="16,16,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="⚡" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Q3Title}" FontWeight="Bold" Foreground="#075985" FontSize="16"/>
                                        <TextBlock Text="{DynamicResource Q3Subtitle}" FontSize="11" Foreground="#0369A1" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Padding="16">
                                <ItemsControl ItemsSource="{Binding Q3Tasks}">
                                    <ItemsControl.ItemTemplate><StaticResource ResourceKey="TaskItemTemplate"/></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Q4: Not Urgent & Not Important -->
                    <Border Grid.Row="1" Grid.Column="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="16" Margin="10,10,0,0">
                        <i:Interaction.Behaviors>
                            <behaviors:DropTargetBehavior TargetQuadrant="NotUrgentNotImportant" MoveTaskCommand="{Binding MoveTaskToQuadrantCommand}"/>
                        </i:Interaction.Behaviors>
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Padding="20,16" Background="#F1F5F9" CornerRadius="16,16,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="🌊" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Q4Title}" FontWeight="Bold" Foreground="#334155" FontSize="16"/>
                                        <TextBlock Text="{DynamicResource Q4Subtitle}" FontSize="11" Foreground="#475569" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Padding="16">
                                <ItemsControl ItemsSource="{Binding Q4Tasks}">
                                    <ItemsControl.ItemTemplate><StaticResource ResourceKey="TaskItemTemplate"/></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                </Grid>
            </Grid>

            <!-- Completed View -->
            <Grid Grid.Column="1" IsVisible="{Binding ShowCompletedView}" Margin="24">
                <Border Background="White" CornerRadius="20" BoxShadow="0 4 6 -1 #0D000000, 0 2 4 -2 #0D000000">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="24,20" Background="#F1F5F9" CornerRadius="20,20,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock Text="✅" FontSize="24" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CompletedTasks}" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock Text="{DynamicResource ArchiveSubtitle}" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Padding="20">
                            <ItemsControl ItemsSource="{Binding CompletedTasks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:TaskItem">
                                        <Border Classes="TaskCard" Width="300" Margin="10" Padding="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="{Binding Title}" TextWrapping="Wrap" FontSize="14" 
                                                           Foreground="#64748B" TextDecorations="Strikethrough" Margin="0,0,0,12"/>
                                                <TextBlock Grid.Row="1" Text="{Binding CompletedAt, StringFormat='Completed At: {0:yyyy-MM-dd HH:mm}'}" 
                                                           FontSize="10" Foreground="#94A3B8" Margin="0,0,0,12"/>
                                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                                    <Button Content="{DynamicResource Restore}" Classes="IconButton RestoreButton" 
                                                            Command="{Binding $parent[Window].DataContext.RestoreTaskCommand}" CommandParameter="{Binding}"
                                                            Padding="12,4" FontSize="11"/>
                                                    <Button Content="🗑️" Classes="IconButton DeleteButton" 
                                                            Command="{Binding $parent[Window].DataContext.DeleteTaskCommand}" CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>

    <Window.Resources>
        <!-- Task Item Template used across quadrants -->
        <DataTemplate x:Key="TaskItemTemplate" x:DataType="models:TaskItem">
            <Border Classes="TaskCard" Padding="14">
                <i:Interaction.Behaviors>
                    <behaviors:DragDropBehavior TaskItem="{Binding}"/>
                </i:Interaction.Behaviors>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Title}" TextWrapping="Wrap" FontSize="14" FontWeight="Medium" 
                               Foreground="#1E293B" LineHeight="20" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="✏️" Classes="IconButton EditButton" 
                                Command="{Binding $parent[Window].DataContext.EditTaskCommand}" CommandParameter="{Binding}"
                                ToolTip.Tip="{DynamicResource Edit}"/>
                        <Button Content="✔️" Classes="IconButton CompleteButton" 
                                Command="{Binding $parent[Window].DataContext.CompleteTaskCommand}" CommandParameter="{Binding}"
                                ToolTip.Tip="{DynamicResource Complete}"/>
                        <Button Content="🗑️" Classes="IconButton DeleteButton" 
                                Command="{Binding $parent[Window].DataContext.DeleteTaskCommand}" CommandParameter="{Binding}"
                                ToolTip.Tip="{DynamicResource Delete}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
</Window>