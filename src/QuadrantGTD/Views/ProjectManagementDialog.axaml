<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadrantGTD.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="600"
        x:Class="QuadrantGTD.Views.ProjectManagementDialog"
        x:DataType="vm:ProjectManagementDialogViewModel"
        Title="{DynamicResource ProjectManagementTitle}"
        Width="550" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F8FAFC">

    <Design.DataContext>
        <vm:ProjectManagementDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *, Auto" Margin="32">
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{DynamicResource ProjectManagementTitle}" 
                   FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,24"/>

        <!-- Main Area -->
        <Grid Grid.Row="1" RowDefinitions="Auto, *">
            <!-- Add New Project Section -->
            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,24" BoxShadow="0 1 3 0 #0D000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="{DynamicResource AddNewProject}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <Grid ColumnDefinitions="*, 12, Auto">
                        <TextBox Grid.Column="0" Text="{Binding NewProjectName}" Watermark="{DynamicResource ProjectName}" CornerRadius="8"/>
                        <ComboBox Grid.Column="2" ItemsSource="{Binding NewProjectColor}" SelectedItem="{Binding NewProjectColor}" Width="80" CornerRadius="8">
                            <ComboBox.Items>
                                <x:String>#F44336</x:String>
                                <x:String>#E91E63</x:String>
                                <x:String>#9C27B0</x:String>
                                <x:String>#2196F3</x:String>
                                <x:String>#00BCD4</x:String>
                                <x:String>#4CAF50</x:String>
                                <x:String>#FF9800</x:String>
                                <x:String>#795548</x:String>
                            </ComboBox.Items>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="20" Height="20" Background="{Binding}" CornerRadius="10"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                    <Button Content="{DynamicResource AddProject}" Classes="HeaderButton" HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Center" Command="{Binding AddProjectCommand}"/>
                </StackPanel>
            </Border>

            <!-- Project List Section -->
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Projects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,12" BoxShadow="0 1 2 0 #05000000">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Border Grid.Column="0" Width="12" Height="12" Background="{Binding Color}" CornerRadius="6" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='Created At: {0:yyyy-MM-dd}'}" FontSize="11" Foreground="#94A3B8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                        <Button Content="✏️" Classes="IconButton EditButton" 
                                                Command="{Binding $parent[Window].DataContext.EditProjectCommand}" CommandParameter="{Binding}"/>
                                        <Button Content="🗑️" Classes="IconButton DeleteButton" 
                                                Command="{Binding $parent[Window].DataContext.DeleteProjectCommand}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Button Grid.Row="2" Content="{DynamicResource Close}" Click="CloseButton_Click" 
                Background="#F1F5F9" Foreground="#475569" HorizontalAlignment="Right" Width="100" Padding="0,10" Margin="0,24,0,0"/>
    </Grid>
</Window>