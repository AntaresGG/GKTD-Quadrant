<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QuadrantGTD.App"
             xmlns:local="using:QuadrantGTD"
             xmlns:themes="clr-namespace:Material.Styles.Themes;assembly=Material.Styles"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default language is loaded in App.axaml.cs, but we can put a placeholder or default here -->
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Global Colors & Constants -->
            <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
            <!-- 优化中英文字体组合：优先使用系统标准无衬线字体，确保中文工整 -->
            <FontFamily x:Key="MainFont">Segoe UI, Microsoft YaHei, Hiragino Sans GB, Arial, sans-serif</FontFamily>
            
            <Color x:Key="PrimaryColor">#4F46E5</Color>
            <Color x:Key="PrimaryHoverColor">#4338CA</Color>
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
            
            <Color x:Key="SuccessColor">#10B981</Color>
            <Color x:Key="DangerColor">#EF4444</Color>
            <Color x:Key="WarningColor">#F59E0B</Color>
            
            <BoxShadows x:Key="StandardShadow">0 2 10 0 #15000000</BoxShadows>
            <BoxShadows x:Key="HoverShadow">0 4 20 0 #20000000</BoxShadows>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <themes:MaterialTheme BaseTheme="Light" PrimaryColor="Indigo" SecondaryColor="Amber" />
        
        <!-- 全局字体渲染优化 -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <!-- Header Buttons -->
        <Style Selector="Button.HeaderButton">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        
        <Style Selector="Button.HeaderButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Secondary Header Buttons (Grayish) -->
        <Style Selector="Button.SecondaryHeaderButton">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>

        <Style Selector="Button.SecondaryHeaderButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Task Card Style Upgrade -->
        <Style Selector="Border.TaskCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
            <Setter Property="BoxShadow" Value="{StaticResource StandardShadow}"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                    <ThicknessTransition Property="Margin" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Border.TaskCard:pointerover">
            <Setter Property="BoxShadow" Value="{StaticResource HoverShadow}"/>
            <Setter Property="Margin" Value="0,6,0,10"/>
        </Style>

        <!-- Icon Button Styles (Circular) -->
        <Style Selector="Button.IconButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.EditButton">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>
        </Style>
        <Style Selector="Button.EditButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button.CompleteButton">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
        <Style Selector="Button.CompleteButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button.DeleteButton">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#EF4444"/>
        </Style>
        <Style Selector="Button.DeleteButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.RestoreButton">
            <Setter Property="Background" Value="#FFFBEB"/>
            <Setter Property="Foreground" Value="#D97706"/>
        </Style>
        <Style Selector="Button.RestoreButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Sidebar Filter Buttons -->
        <Style Selector="Button.ProjectFilterButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        
        <Style Selector="Button.ProjectFilterButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

    </Application.Styles>
</Application>